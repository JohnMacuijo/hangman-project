<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootLayout" alignment="TOP_CENTER" prefHeight="850.0" prefWidth="950.0" spacing="15.0" style="-fx-background-color: #0b0c10; -fx-font-family: 'Segoe UI', Helvetica, Arial, sans-serif;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.BossBattleController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <Label style="-fx-effect: dropshadow(three-pass-box, rgba(255,122,0,0.4), 10, 0, 0, 0);" text="👑 THE HANGMAN KING'S CHALLENGE" textFill="#ff7a00">
            <font>
                <Font name="Impact" size="30.0" />
            </font>
        </Label>
        <Label style="-fx-font-weight: bold;" text="SAVE THE PRISONER BEFORE TIME RUNS OUT" textFill="#8b949e">
            <font>
                <Font size="12.0" />
            </font>
        </Label>
    </VBox>

    <VBox maxWidth="850.0" prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: #161b22; -fx-background-radius: 12px; -fx-border-color: #30363d; -fx-border-radius: 12px; -fx-border-width: 1px;">

        <HBox alignment="CENTER" prefHeight="330.0" spacing="40.0" style="-fx-border-color: #30363d; -fx-border-width: 0 0 1px 0;">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>

            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="10.0" style="-fx-border-color: #30363d; -fx-border-width: 0 1px 0 0;">
                <padding>
                    <Insets right="20.0" />
                </padding>
                <ImageView fx:id="hangmanImageView" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />

                <VBox spacing="5.0">
                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold;" text="Prisoner's Fate" textFill="#8b949e" />
                        <StackPane HBox.hgrow="ALWAYS" />
                        <Label fx:id="stageLabel" style="-fx-font-size: 11px; -fx-font-weight: bold;" text="0 / 10" textFill="#8b949e" />
                    </HBox>
                    <ProgressBar fx:id="dangerProgressBar" prefWidth="220.0" progress="0.0" style="-fx-accent: #ff7a00; -fx-control-inner-background: #0d1117; -fx-background-insets: 0; -fx-padding: 0; -fx-background-radius: 4px;" />
                </VBox>
            </VBox>

            <VBox alignment="CENTER" spacing="20.0" HBox.hgrow="ALWAYS">

                <!-- WORDS SAVED + TIMER row -->
                <HBox alignment="CENTER" spacing="16">

                    <HBox alignment="CENTER" spacing="5" style="-fx-background-color: #0d1117; -fx-padding: 6px 15px; -fx-background-radius: 15px; -fx-border-color: #30363d; -fx-border-radius: 15px;">
                        <Label style="-fx-font-weight:bold; -fx-font-size:12px;" text="WORDS SAVED:" textFill="#8b949e" />
                        <Label fx:id="progressLabel" style="-fx-font-weight:bold; -fx-font-size:12px;" text="0 / 10" textFill="#ff7a00" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="5" style="-fx-background-color: #0d1117; -fx-padding: 6px 15px; -fx-background-radius: 15px; -fx-border-color: #30363d; -fx-border-radius: 15px;">
                        <Label style="-fx-font-weight:bold; -fx-font-size:12px;" text="TIME:" textFill="#8b949e" />
                        <Label fx:id="timerLabel" style="-fx-font-weight:bold; -fx-font-size:12px;" text="10" textFill="#ff4a4a" />
                    </HBox>

                </HBox>

                <!-- King's taunt / flavor line -->
                <HBox alignment="CENTER">
                    <Label fx:id="narrativeLabel" alignment="CENTER" maxWidth="520.0" prefWidth="520.0" style="-fx-background-color: #0d1117; -fx-padding: 10px 20px; -fx-background-radius: 15px; -fx-border-color: #30363d; -fx-border-radius: 15px; -fx-font-weight:bold; -fx-font-size:12px; -fx-font-style: italic;" text="The Hangman King awaits your first word..." textAlignment="CENTER" textFill="#ffd166" wrapText="true" />
                </HBox>

                <HBox fx:id="wordDisplayBox" alignment="CENTER" prefHeight="60.0" spacing="10.0">
                </HBox>

                <Label fx:id="wordLengthLabel" style="-fx-font-size: 11px; -fx-font-weight: bold;" text="7 letters" textFill="#8b949e" />

                <HBox fx:id="statusContainer" alignment="CENTER" managed="false" maxWidth="620.0" visible="false">
                    <Label fx:id="statusLabel" alignment="CENTER" maxWidth="580.0" text="" textAlignment="CENTER" textFill="#f85149" wrapText="true" />
                </HBox>
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="25.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="25.0" left="20.0" right="20.0" top="25.0" />
            </padding>
            <Label style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1.5px;" text="PICK A LETTER -- NO AID FROM HERE ON" textFill="#8b949e" />

            <GridPane fx:id="keyboardGrid" alignment="CENTER" hgap="10.0" vgap="10.0">
            </GridPane>

            <!-- Shown only once the run ends, win or lose -->
            <HBox alignment="CENTER" spacing="15.0">
                <Button fx:id="mainMenuBtn" managed="false" onAction="#backToMenu" prefHeight="40.0" prefWidth="170.0" style="-fx-background-color: transparent; -fx-text-fill: #c9d1d9; -fx-border-color: #30363d; -fx-border-width: 1.5px; -fx-border-radius: 20px; -fx-background-radius: 20px; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Back to Menu" visible="false" />
            </HBox>
        </VBox>
    </VBox>

    <Label style="-fx-font-weight: bold; -fx-font-size: 10px; -fx-letter-spacing: 1px;" text="TYPE ON YOUR KEYBOARD TO GUESS" textFill="#484f58" />
</VBox>
