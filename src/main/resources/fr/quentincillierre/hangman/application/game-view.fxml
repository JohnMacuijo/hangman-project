<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:id="rootLayout" alignment="TOP_CENTER" prefHeight="850.0" prefWidth="950.0" spacing="15.0" style="-fx-background-color: #0b0c10; -fx-font-family: 'Segoe UI', Helvetica, Arial, sans-serif;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.GameController">
    
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <Label style="-fx-effect: dropshadow(three-pass-box, rgba(255,122,0,0.4), 10, 0, 0, 0);" text="HANGMAN" textFill="#ff7a00">
            <font>
                <Font name="Impact" size="48.0" />
            </font>
        </Label>
        <Label style="-fx-font-weight: bold;" text="GUESS THE WORD BEFORE IT'S TOO LATE" textFill="#8b949e">
            <font>
                <Font size="12.0" />
            </font>
        </Label>
    </VBox>

    <VBox maxWidth="850.0" prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: #161b22; -fx-background-radius: 12px; -fx-border-color: #30363d; -fx-border-radius: 12px; -fx-border-width: 1px;">
        
        <HBox alignment="CENTER" prefHeight="330.0" spacing="40.0" style="-fx-border-color: #30363d; -fx-border-width: 0 0 1px 0;">
            <padding>
                <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
            </padding>
            
            <VBox alignment="CENTER_LEFT" prefWidth="250.0" spacing="10.0" style="-fx-border-color: #30363d; -fx-border-width: 0 1px 0 0;">
                <padding>
                    <Insets right="20.0" />
                </padding>
                <ImageView fx:id="hangmanImageView" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                
                <VBox spacing="5.0">
                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-font-size: 11px; -fx-font-weight: bold;" text="Danger" textFill="#8b949e" />
                        <StackPane HBox.hgrow="ALWAYS" />
                        <Label fx:id="wrongLabel" style="-fx-font-size: 11px; -fx-font-weight: bold;" text="6 left" textFill="#8b949e" />
                    </HBox>
                    <ProgressBar fx:id="dangerProgressBar" prefWidth="220.0" progress="0.0" style="-fx-accent: #ff7a00; -fx-control-inner-background: #0d1117; -fx-background-insets: 0; -fx-padding: 0; -fx-background-radius: 4px;" />
                </VBox>
            </VBox>
            
            <VBox alignment="CENTER" spacing="20.0" HBox.hgrow="ALWAYS">

                <!-- SCORE + BEST + TIMER row -->
                <HBox alignment="CENTER" spacing="16">

                    <!-- Score -->
                    <HBox alignment="CENTER" spacing="5" style="-fx-background-color: #0d1117;                                  -fx-padding: 6px 15px;                                  -fx-background-radius: 15px;                                  -fx-border-color: #30363d;                                  -fx-border-radius: 15px;">

                        <Label style="-fx-font-weight:bold; -fx-font-size:12px;" text="SCORE:" textFill="#8b949e" />

                        <Label fx:id="scoreLabel" style="-fx-font-weight:bold; -fx-font-size:12px;" text="0" textFill="#ff7a00" />

                    </HBox>

                    <!-- Best, right beside Score -->
                    <HBox alignment="CENTER" spacing="5" style="-fx-background-color: #0d1117;                                  -fx-padding: 6px 15px;                                  -fx-background-radius: 15px;                                  -fx-border-color: #30363d;                                  -fx-border-radius: 15px;">

                        <Label style="-fx-font-weight:bold; -fx-font-size:12px;" text="BEST:" textFill="#8b949e" />

                        <Label fx:id="highScoreLabel" style="-fx-font-weight:bold; -fx-font-size:12px;" text="0" textFill="#c9d1d9" />

                    </HBox>

                    <!-- Timer -->
                    <HBox alignment="CENTER" spacing="5" style="-fx-background-color: #0d1117;                                  -fx-padding: 6px 15px;                                  -fx-background-radius: 15px;                                  -fx-border-color: #30363d;                                  -fx-border-radius: 15px;">

                        <Label style="-fx-font-weight:bold; -fx-font-size:12px;" text="TIME:" textFill="#8b949e" />

                        <Label fx:id="timerLabel" style="-fx-font-weight:bold; -fx-font-size:12px;" text="60" textFill="#ff4a4a" />

                    </HBox>

                </HBox>

                <!-- HINT row, below Score/Best/Timer -->
                <HBox alignment="CENTER">
                    <HBox alignment="CENTER" spacing="5" style="-fx-background-color: #0d1117;                                  -fx-padding: 6px 15px;                                  -fx-background-radius: 15px;                                  -fx-border-color: #30363d;                                  -fx-border-radius: 15px;">

                        <Label style="-fx-font-weight:bold; -fx-font-size:12px;" text="HINT:" textFill="#8b949e" />

                        <Label fx:id="hintLabel" style="-fx-font-weight:bold; -fx-font-size:12px;" text="Ancient structure" textFill="#ff7a00" />

                    </HBox>
                </HBox>

                <HBox fx:id="wordDisplayBox" alignment="CENTER" prefHeight="60.0" spacing="10.0">
                </HBox>
                
                <Label fx:id="wordLengthLabel" style="-fx-font-size: 11px; -fx-font-weight: bold;" text="7 letters" textFill="#8b949e" />

                <HBox fx:id="statusContainer" alignment="CENTER" managed="false" visible="false">
                    <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(248,81,73,0.15); -fx-border-color: #f85149; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 10px 25px;">
                        <Label fx:id="statusLabel" style="-fx-font-weight: bold; -fx-font-size: 15px;" text="💀 Game over — it was &quot;PYRAMID&quot;" textFill="#f85149" />
                    </HBox>
                </HBox>
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="25.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="25.0" left="20.0" right="20.0" top="25.0" />
            </padding>
            <Label style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1.5px;" text="PICK A LETTER" textFill="#8b949e" />

            <!-- Keyboard + letter-unlock bulb, side by side -->
            <HBox alignment="CENTER" spacing="20.0">
                <GridPane fx:id="keyboardGrid" alignment="CENTER" hgap="10.0" vgap="10.0">
                </GridPane>

                <VBox alignment="CENTER" spacing="6.0">
                    <Button fx:id="hintButton" onAction="#unlockLetter" prefHeight="46.0" prefWidth="46.0" style="-fx-background-color: transparent; -fx-border-color: #ffd166; -fx-border-width: 1.5px; -fx-border-radius: 23px; -fx-background-radius: 23px; -fx-font-size: 18px; -fx-cursor: hand;" text="💡">
                        <tooltip>
                            <Tooltip text="Unlocks one random letter -- costs 5 seconds!" />
                        </tooltip>
                    </Button>
                    <Label style="-fx-font-size: 10px; -fx-font-weight: bold;" text="Unlock a letter" textFill="#ffd166" />
                    <Label style="-fx-font-size: 10px; -fx-font-weight: bold;" text="-5s" textFill="#8b949e" />
                </VBox>
            </HBox>

            <!-- Play Again / Back to Menu, hidden until the game actually ends -->
            <HBox alignment="CENTER" spacing="15.0">
                <Button fx:id="restartBtn" onAction="#restart" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #ff7a00; -fx-text-fill: #0b0c10; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(255,122,0,0.3), 8, 0, 0, 0);" text="Play Again" visible="false" managed="false" />

                <Button fx:id="mainMenuBtn" managed="false" onAction="#backToMenu" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: transparent; -fx-text-fill: #c9d1d9; -fx-border-color: #30363d; -fx-border-width: 1.5px; -fx-border-radius: 20px; -fx-background-radius: 20px; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;" text="Back to Menu" visible="false" />
            </HBox>
        </VBox>
    </VBox>
    
    <Label style="-fx-font-weight: bold; -fx-font-size: 10px; -fx-letter-spacing: 1px;" text="TYPE ON YOUR KEYBOARD TO GUESS" textFill="#484f58" />
</VBox>
