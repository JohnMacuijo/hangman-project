<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>

<VBox
    alignment="TOP_CENTER"
    prefHeight="850"
    prefWidth="950"
    spacing="15"
    stylesheets="@css/style.css"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="fr.quentincillierre.hangman.controller.DifficultyController">


    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>


    <VBox alignment="CENTER" spacing="5">

        <Label text="HANGMAN"
               textFill="#ff7a00"/>

        <Label text="GUESS THE WORD BEFORE IT'S TOO LATE"
               textFill="#8b949e"/>

    </VBox>


    <VBox alignment="CENTER"
          maxWidth="500"
          prefWidth="500"
          prefHeight="500"
          spacing="20"
          style="-fx-background-color:#161b22;
                 -fx-background-radius:12;
                 -fx-border-color:#30363d;
                 -fx-border-radius:12;">


        <Label text="CHOOSE DIFFICULTY"
               textFill="white"/>


        <VBox alignment="CENTER" spacing="15">

            <Button fx:id="easyButton"
                    text="🟢 EASY&#10;Short words • 90 seconds"
                    onAction="#selectEasy"
                    styleClass="difficulty-button"/>


            <Button fx:id="mediumButton"
                    text="🟠 MEDIUM&#10;Everyday words • 60 seconds"
                    onAction="#selectMedium"
                    styleClass="difficulty-button"/>


            <Button fx:id="hardButton"
                    text="🔴 HARD&#10;Long words • 45 seconds"
                    onAction="#selectHard"
                    styleClass="difficulty-button"/>

        </VBox>


        <Button fx:id="startButton"
                text="START GAME"
                onAction="#startGame"
                styleClass="start-button"/>


    </VBox>


</VBox>
