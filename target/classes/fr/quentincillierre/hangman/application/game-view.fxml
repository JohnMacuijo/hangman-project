<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="15.0" prefHeight="850.0" prefWidth="950.0" 
      style="-fx-background-color: #0b0c10; -fx-font-family: 'Segoe UI', Helvetica, Arial, sans-serif;" 
      xmlns="http://javafx.com/javafx/17" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="fr.quentincillierre.hangman.controller.GameController">
    
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
    </padding>

    <VBox alignment="CENTER" spacing="5.0">
        <Label text="HANGMAN" textFill="#ff7a00" style="-fx-effect: dropshadow(three-pass-box, rgba(255,122,0,0.4), 10, 0, 0, 0);">
            <font>
                <Font name="Impact" size="48.0" />
            </font>
        </Label>
        <Label text="GUESS THE WORD BEFORE IT'S TOO LATE" textFill="#8b949e" style="-fx-font-weight: bold;">
            <font>
                <Font size="12.0" />
            </font>
        </Label>
    </VBox>

    <VBox prefHeight="650.0" prefWidth="850.0" maxWidth="850.0"
          style="-fx-background-color: #161b22; -fx-background-radius: 12px; -fx-border-color: #30363d; -fx-border-radius: 12px; -fx-border-width: 1px;">
        
        <HBox prefHeight="330.0" alignment="CENTER" spacing="40.0" style="-fx-border-color: #30363d; -fx-border-width: 0 0 1px 0;">
            <padding>
                <Insets top="20.0" bottom="20.0" left="30.0" right="30.0" />
            </padding>
            
            <VBox alignment="CENTER_LEFT" spacing="10.0" prefWidth="250.0" style="-fx-border-color: #30363d; -fx-border-width: 0 1px 0 0;">
                <padding>
                    <Insets right="20.0" />
                </padding>
                <ImageView fx:id="hangmanImageView" fitHeight="200.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true" />
                
                <VBox spacing="5.0">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Danger" textFill="#8b949e" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                        <StackPane HBox.hgrow="ALWAYS" />
                        <Label fx:id="wrongLabel" text="6 left" textFill="#8b949e" style="-fx-font-size: 11px; -fx-font-weight: bold;"/>
                    </HBox>
                    <ProgressBar fx:id="dangerProgressBar" progress="0.0" prefWidth="220.0" 
                                 style="-fx-accent: #ff4a4a; -fx-control-inner-background: #0d1117; -fx-background-insets: 0; -fx-padding: 0; -fx-background-radius: 4px;" />
                </VBox>
            </VBox>
            
            <VBox alignment="CENTER" spacing="20.0" HBox.hgrow="ALWAYS">
               <HBox alignment="CENTER" spacing="20">

    <!-- Hint -->
    <HBox alignment="CENTER" spacing="5"
          style="-fx-background-color: #0d1117;
                 -fx-padding: 6px 15px;
                 -fx-background-radius: 15px;
                 -fx-border-color: #30363d;
                 -fx-border-radius: 15px;">

        <Label text="HINT:"
               textFill="#8b949e"
               style="-fx-font-weight:bold; -fx-font-size:12px;"/>

        <Label fx:id="hintLabel"
               text="Ancient structure"
               textFill="#ff7a00"
               style="-fx-font-weight:bold; -fx-font-size:12px;"/>

    </HBox>

    <!-- Timer -->
    <HBox alignment="CENTER" spacing="5"
          style="-fx-background-color: #0d1117;
                 -fx-padding: 6px 15px;
                 -fx-background-radius: 15px;
                 -fx-border-color: #30363d;
                 -fx-border-radius: 15px;">

        <Label text="TIME:"
               textFill="#8b949e"
               style="-fx-font-weight:bold; -fx-font-size:12px;"/>

        <Label fx:id="timerLabel"
               text="60"
               textFill="#ff4a4a"
               style="-fx-font-weight:bold; -fx-font-size:12px;"/>

    </HBox>

</HBox>

                <HBox fx:id="wordDisplayBox" alignment="CENTER" spacing="10.0" prefHeight="60.0">
                </HBox>
                
                <Label fx:id="wordLengthLabel" text="7 letters" textFill="#8b949e" style="-fx-font-size: 11px; -fx-font-weight: bold;" />

                <HBox alignment="CENTER" fx:id="statusContainer" visible="false" managed="false">
                    <HBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(248,81,73,0.15); -fx-border-color: #f85149; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-padding: 10px 25px;">
                        <Label fx:id="statusLabel" text="💀 Game over — it was &quot;PYRAMID&quot;" textFill="#f85149" style="-fx-font-weight: bold; -fx-font-size: 15px;" />
                    </HBox>
                </HBox>
            </VBox>
        </HBox>

        <VBox alignment="CENTER" spacing="25.0" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="25.0" bottom="25.0" left="20.0" right="20.0" />
            </padding>
            <Label text="PICK A LETTER" textFill="#8b949e" style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-letter-spacing: 1.5px;"/>
            
            <GridPane fx:id="keyboardGrid" alignment="CENTER" hgap="10.0" vgap="10.0">
            </GridPane>

            <HBox alignment="CENTER" spacing="15.0">
                <Button fx:id="restartBtn" text="New Word" onAction="#restart" prefHeight="40.0" prefWidth="150.0" 
                        style="-fx-background-color: #ff7a00; -fx-text-fill: #0b0c10; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(255,122,0,0.3), 8, 0, 0, 0);"/>
            </HBox>
        </VBox>
    </VBox>
    
    <Label text="TYPE ON YOUR KEYBOARD TO GUESS" textFill="#484f58" style="-fx-font-weight: bold; -fx-font-size: 10px; -fx-letter-spacing: 1px;" />
</VBox>